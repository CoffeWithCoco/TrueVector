# --- Application access ---
# SECRET_KEY: signs session cookies.
#   If left empty, one is generated and stored in data/secret_key automatically.
# SECRET_KEY=

# ADMIN_USERNAME: login username (defaults to "admin").
ADMIN_USERNAME=admin

# ADMIN_PASSWORD: if left empty, a secure password is GENERATED on first boot and
#   printed to the console once (docker compose logs web).
#   Set it only if you want to pin your own.
# ADMIN_PASSWORD=

# HTTPS_ONLY: set to "true" only when serving the app behind HTTPS/TLS.
HTTPS_ONLY=false

# --- Database ---
DATABASE_URL=sqlite:////app/data/smtp_validator.db
